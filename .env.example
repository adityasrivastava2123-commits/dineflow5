# Frontend Environment Variables
VITE_API_BASE_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
VITE_RAZORPAY_KEY=your_razorpay_key_here
VITE_APP_NAME=DineFlow Pro

# Backend Environment Variables
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dineflow
MONGODB_DB_NAME=dineflow

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email/WhatsApp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_TOKEN=

# Socket.io
SOCKET_TRANSPORTS=websocket,polling

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173

# Sentry (Optional)
SENTRY_DSN=

# Analytics
MIXPANEL_TOKEN=

# App Config
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
PAYMENT_REDIRECT_URL=http://localhost:5173/order-status
